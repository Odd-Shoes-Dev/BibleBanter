{
  "name": "bible-battle-server",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles --testPathIgnorePatterns \"Bible-Banter - Copy/\" \"client/\"",
    "postinstall": "node scripts/postinstall.js",
    "seed": "node prisma/seed.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "prisma": "^5.22.0",
    "socket.io": "^4.7.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
