generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Host {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String?
  googleId     String?       @unique
  name         String
  createdAt    DateTime      @default(now())
  questionSets QuestionSet[]
  games        Game[]
}

model QuestionSet {
  id          String     @id @default(cuid())
  name        String
  description String?
  testament   String     @default("both") // "Old Testament" | "New Testament" | "both"
  isDefault   Boolean    @default(false)
  hostId      String?
  host        Host?      @relation(fields: [hostId], references: [id], onDelete: SetNull)
  questions   Question[]
  games       Game[]
  createdAt   DateTime   @default(now())
}

model Question {
  id         String      @id @default(cuid())
  question   String
  options    String[]
  answer     Int
  category   String      @default("General")
  difficulty String      @default("medium")
  scripture  String?
  setId      String
  set        QuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
}

model Game {
  id            String         @id @default(cuid())
  pin           String         @unique
  status        String         @default("lobby") // lobby | playing | finished
  hostId        String?
  host          Host?          @relation(fields: [hostId], references: [id], onDelete: SetNull)
  setId         String?
  set           QuestionSet?   @relation(fields: [setId], references: [id], onDelete: SetNull)
  players       Player[]
  sessionReport SessionReport?
  createdAt     DateTime       @default(now())
  finishedAt    DateTime?
}

model Player {
  name      String
  gameId    String
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  score     Int            @default(0)
  streak    Int            @default(0)
  rank      Int?
  joinedAt  DateTime       @default(now())
  answers   PlayerAnswer[]

  @@id([name, gameId])
}

model PlayerAnswer {
  id             String   @id @default(cuid())
  playerName     String
  gameId         String
  player         Player   @relation(fields: [playerName, gameId], references: [name, gameId], onDelete: Cascade)
  questionIndex  Int
  answerIndex    Int
  isCorrect      Boolean
  pointsEarned   Int      @default(0)
  responseTimeMs Int      @default(0)
  answeredAt     DateTime @default(now())
}

model SessionReport {
  id        String   @id @default(cuid())
  gameId    String   @unique
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  hostId    String
  summary   String
  data      Json
  createdAt DateTime @default(now())
}
